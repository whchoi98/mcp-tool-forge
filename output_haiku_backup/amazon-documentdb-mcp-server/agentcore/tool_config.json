    {
      "toolSpec": {
        "name": "analyzeSchema",
        "description": "Analyze the schema of a collection by sampling documents.",
        "inputSchema": {
          "json": {
            "type": "object",
            "properties": {
              "connection_id": {
                "type": "string",
                "description": "The connection ID returned by the connect tool"
              },
              "database": {
                "type": "string",
                "description": "Name of the database"
              },
              "collection": {
                "type": "string",
                "description": "Name of the collection to analyze"
              },
              "sample_size": {
                "type": "integer",
                "description": "Number of documents to sample (default: 100)"
              }
            },
            "required": [
              "connection_id",
              "database",
              "collection"
            ]
          }
        }
      }
    },
    {
      "toolSpec": {
        "name": "explainOperation",
        "description": "Get an explanation of how an operation will be executed.",
        "inputSchema": {
          "json": {
            "type": "object",
            "properties": {
              "connection_id": {
                "type": "string",
                "description": "The connection ID returned by the connect tool"
              },
              "database": {
                "type": "string",
                "description": "Name of the database"
              },
              "collection": {
                "type": "string",
                "description": "Name of the collection"
              },
              "operation_type": {
                "type": "string",
                "description": "Type of operation to explain (find, aggregate)"
              },
              "query": {
                "type": "string",
                "description": "Query for find operations"
              },
              "pipeline": {
                "type": "string",
                "description": "Pipeline for DocumentDB aggregation operations"
              },
              "verbosity": {
                "type": "string",
                "description": "Explanation verbosity level (queryPlanner, executionStats)"
              }
            },
            "required": [
