              }
            },
            "required": [
              "connection_id",
              "database"
            ]
          }
        }
      }
    },
    {
      "toolSpec": {
        "name": "dropCollection",
        "description": "Drop a collection from a DocumentDB database.",
        "inputSchema": {
          "json": {
            "type": "object",
            "properties": {
              "connection_id": {
                "type": "string",
                "description": "The connection ID returned by the connect tool"
              },
              "database": {
                "type": "string",
                "description": "Name of the database"
              },
              "collection": {
                "type": "string",
