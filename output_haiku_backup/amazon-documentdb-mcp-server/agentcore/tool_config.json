        "inputSchema": {
          "json": {
            "type": "object",
            "properties": {
              "connection_id": {
                "type": "string",
                "description": "The connection ID returned by the connect tool"
              },
              "database": {
                "type": "string",
                "description": "Name of the database"
              },
              "collection": {
                "type": "string",
                "description": "Name of the collection"
              },
              "filter": {
                "type": "string",
                "description": "Query filter to count specific documents"
              }
            },
            "required": [
              "connection_id",
              "database",
              "collection"
            ]
          }
        }
      }
    },
