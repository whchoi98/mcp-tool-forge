  "tools": [
    {
      "toolSpec": {
        "name": "list_users",
        "description": "List IAM users in the account.",
        "inputSchema": {
          "json": {
            "type": "object",
            "properties": {
              "ctx": {
                "type": "string",
                "description": ""
              },
              "path_prefix": {
                "type": "string",
                "description": "Path prefix to filter users (e.g., \"/division_abc/\")"
              },
              "max_items": {
                "type": "integer",
                "description": "Maximum number of users to return"
              }
            },
            "required": [
              "ctx"
            ]
          }
        }
      }
    },
    {
      "toolSpec": {
