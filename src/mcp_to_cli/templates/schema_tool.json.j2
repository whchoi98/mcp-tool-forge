{# Auto-generated OpenAPI tool schema template / 자동 생성 OpenAPI 도구 스키마 템플릿 #}
{
  "name": "{{ tool.name }}",
  "description": {{ tool.description | tojson }},
  "parameters": {
    "type": "object",
    "properties": {
{% for param in tool.params %}
      "{{ param.name }}": {
        "type": "{{ param.type }}",
        "description": {{ param.description | tojson }}
      }{% if not loop.last %},{% endif %}

{% endfor %}
    },
    "required": [{% for p in tool.params if p.required %}"{{ p.name }}"{% if not loop.last %}, {% endif %}{% endfor %}]
  }
}
